# ─── Supabase ──────────────────────────────────────────────
# 1. Create a project at https://supabase.com
# 2. Go to Project Settings → API
# 3. Copy "Project URL" and "anon public" key

PUBLIC_SUPABASE_URL=https://dummy.supabase.co
PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.dummy

# ─── Telegram Bot ──────────────────────────────────────────
# 1. Open Telegram, search @BotFather → /newbot → follow steps
# 2. Copy the token it gives you
# 3. Send any message to your bot, then open:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
#    Copy "chat" → "id" from the result

TELEGRAM_BOT_TOKEN=1234567890:ABCDefGHijKLmnoPQRstuvWXYZ
TELEGRAM_CHAT_ID=123456789

