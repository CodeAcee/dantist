---
import TeamSlider from './TeamSlider';
interface Member { name: string; title: string; bio: string; years: number; yearsLabel: string; imgAlt: string }
interface Props {
  t: { eyebrow: string; quote: string; prevLabel: string; nextLabel: string; team: Member[] };
  locale: string;
}
const { t, locale } = Astro.props;
---
<section class="about-section" id="about" aria-label="About">
  <div class="about-left">
    <div class="about-left-inner">
      <div class="eyebrow eyebrow--light">{t.eyebrow}</div>
      <blockquote class="about-quote">{t.quote}</blockquote>
      <div class="about-deco" aria-hidden="true"></div>
    </div>
  </div>
  <div class="about-right js-reveal">
    <TeamSlider
      client:visible
      locale={locale}
      fallback={t.team}
      prevLabel={t.prevLabel}
      nextLabel={t.nextLabel}
    />
  </div>
</section>
<style>
.about-section {
  display: grid;
  grid-template-columns: 1fr 1fr;
  min-height: 520px;
}
.about-left {
  background: var(--forest);
  padding: 5rem 4rem;
  display: flex;
  align-items: center;
  position: relative;
  overflow: hidden;
}
.about-left::before {
  content: '';
  position: absolute;
  inset: 0;
  background: url("data:image/svg+xml,%3Csvg width='40' height='40' viewBox='0 0 40 40' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='%23fff' fill-opacity='0.025'%3E%3Cpath d='M0 40L40 0H20L0 20M40 40V20L20 40'/%3E%3C/g%3E%3C/svg%3E");
  pointer-events: none;
}
.about-left-inner { position: relative; z-index: 1; }
.about-quote {
  font-family: var(--serif);
  font-size: clamp(18px, 2.2vw, 26px);
  font-weight: 300;
  font-style: italic;
  color: var(--cream);
  line-height: 1.5;
  margin-top: 24px;
  padding-left: 20px;
  border-left: 2px solid var(--gold);
  opacity: .9;
}
.about-deco {
  width: 40px;
  height: 2px;
  background: var(--gold);
  margin-top: 32px;
  opacity: .4;
}
.about-right {
  background: var(--cream-dark);
  padding: 5rem 4rem;
  display: flex;
  align-items: center;
}
.about-right > * { width: 100%; }
@media (max-width: 900px) {
  .about-section { grid-template-columns: 1fr; }
  .about-left { padding: 4rem var(--px); min-height: auto; }
  .about-right { padding: 4rem var(--px); }
}
</style>
