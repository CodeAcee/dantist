---
interface Col  { h: string; links: string[] }
interface Props {
  brand: { name: string; accent: string };
  t: { tagline: string; cols: Col[]; copy: string };
}
const { brand, t } = Astro.props;

const socials = [
  { label: 'TikTok',    href: 'https://www.tiktok.com/@chirkovadentist' },
  { label: 'Instagram', href: 'https://www.instagram.com/chirkovadentist' },
  { label: 'Telegram',  href: 'https://t.me/chirkovadentist' },
  { label: 'Viber',     href: 'viber://chat?number=%2B380561234567' },
  { label: 'WhatsApp',  href: 'https://wa.me/380561234567' },
];
---
<footer class="footer">
  <div class="footer-inner">
    <div class="footer-top">
      <div class="footer-brand">
        <div class="footer-logo">{brand.name} <em>{brand.accent}</em></div>
        <p class="footer-tagline">{t.tagline}</p>
        <div class="footer-social">
          {socials.map(s => (
            <a href={s.href} class="footer-social-link" target="_blank" rel="noopener noreferrer">{s.label}</a>
          ))}
        </div>
      </div>
      {t.cols.map(col => (
        <div class="footer-col">
          <div class="footer-col-head">{col.h}</div>
          {col.links.map(l => <a href="#" class="footer-link">{l}</a>)}
        </div>
      ))}
    </div>
    <div class="footer-bottom">
      <span>{t.copy}</span>
      <span>Privacy · Terms</span>
    </div>
  </div>
</footer>
<style>
.footer { background: var(--text-dark); padding: 4rem 0 2rem; color: rgba(245,240,232,.45); }
.footer-inner { max-width: var(--max-w); margin: 0 auto; padding: 0 var(--px); }
.footer-top { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 3rem; margin-bottom: 3rem; }
.footer-logo { font-family: var(--serif); font-size: 24px; font-weight: 300; color: var(--cream); margin-bottom: 12px; }
.footer-logo em { font-style: italic; color: var(--gold); }
.footer-tagline { font-size: 13px; line-height: 1.7; max-width: 220px; margin-bottom: 20px; }
.footer-social { display: flex; gap: 10px; flex-wrap: wrap; }
.footer-social-link { font-size: 10px; letter-spacing: .08em; color: rgba(245,240,232,.35); text-decoration: none; padding: 5px 10px; border: 1px solid rgba(245,240,232,.1); border-radius: 2px; transition: all .2s; }
.footer-social-link:hover { color: var(--gold); border-color: rgba(200,169,110,.35); }
.footer-col { display: flex; flex-direction: column; gap: 8px; }
.footer-col-head { font-size: 9px; letter-spacing: .16em; text-transform: uppercase; color: var(--gold); margin-bottom: 6px; }
.footer-link { font-size: 13px; color: rgba(245,240,232,.45); text-decoration: none; transition: color .2s; }
.footer-link:hover { color: var(--cream); }
.footer-bottom { border-top: 1px solid rgba(245,240,232,.06); padding-top: 20px; display: flex; justify-content: space-between; font-size: 12px; flex-wrap: wrap; gap: 8px; }
@media (max-width: 900px) { .footer-top { grid-template-columns: 1fr 1fr; gap: 2rem; } .footer-brand { grid-column: 1/-1; } }
@media (max-width: 480px) { .footer-top { grid-template-columns: 1fr; } }
</style>
