---
const items = ['Cosmetic Dentistry','Teeth Whitening','Dental Implants','Invisalign','Veneers','Root Canal','Pediatric Care','Emergency Dental'];
---
<div class="marquee-wrap" aria-hidden="true">
  <div class="marquee-track">
    {[...items, ...items].map((s, i) => (
      <span class="marquee-item" key={i}>
        <span class="marquee-dot"></span>{s}
      </span>
    ))}
  </div>
</div>

<style>
.marquee-wrap {
  background: var(--forest);
  padding: 13px 0;
  overflow: hidden;
  white-space: nowrap;
}
.marquee-track {
  display: inline-flex;
  gap: 3rem;
  animation: marquee 22s linear infinite;
}
.marquee-item {
  font-size: 11px;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: rgba(245,240,232,.45);
  display: flex;
  align-items: center;
  gap: 12px;
}
.marquee-dot {
  width: 4px;
  height: 4px;
  border-radius: 50%;
  background: var(--gold);
  flex-shrink: 0;
}
@media (prefers-reduced-motion: reduce) {
  .marquee-track { animation: none; }
}
</style>
