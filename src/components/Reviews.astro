---
import ReviewsList from './ReviewsList';
interface Review { q: string; n: string; s: string; bg: string; c: string; ini: string }
interface Props {
  t: { eyebrow: string; h2: string; h2em: string; sinceLabel: string; list: Review[] };
  locale: string;
}
const { t, locale } = Astro.props;

const fallback = t.list.map(r => ({
  quote: r.q, name: r.n, since: r.s, bg: r.bg, color: r.c, initials: r.ini,
}));
---
<section class="reviews-section" id="reviews" aria-label="Reviews">
  <div class="section-inner">
    <div class="reviews-header">
      <div>
        <div class="eyebrow">{t.eyebrow}</div>
        <h2 class="reviews-h2">{t.h2}<em>{t.h2em}</em></h2>
      </div>
    </div>
    <ReviewsList client:visible locale={locale} sinceLabel={t.sinceLabel} fallback={fallback} />
  </div>
</section>
<style>
.reviews-section { background: var(--cream); padding: 7rem 0; }
.reviews-header  { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 48px; }
.reviews-h2 { font-family: var(--serif); font-size: clamp(26px,3.5vw,44px); font-weight: 300; color: var(--forest); }
.reviews-h2 em { font-style: italic; }
@media (max-width: 900px) { .reviews-section { padding: 5rem 0; } }
</style>
