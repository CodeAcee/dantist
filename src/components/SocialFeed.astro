---
interface Video { id: string; caption: string }
interface Props {
  t: {
    eyebrow: string; h2: string; h2em: string; sub: string;
    videos: Video[];
    igHandle: string; igFollowers: string; igFollowersLabel: string;
    igPosts: string; igPostsLabel: string; igBio: string;
    igCta: string; tiktokCta: string;
  }
}
const { t } = Astro.props;
const TIKTOK_PROFILE = 'https://www.tiktok.com/@mad__dentist';
const IG_URL = 'https://www.instagram.com/mad__dentist/';
---

<section class="social-section" id="social" aria-label="Social media">
  <div class="section-inner">

    <div class="social-header js-reveal">
      <div class="eyebrow">{t.eyebrow}</div>
      <h2 class="social-h2">{t.h2}<em>{t.h2em}</em></h2>
      <p class="social-sub">{t.sub}</p>
    </div>

    <div class="social-grid">

      {/* TikTok videos */}
      {t.videos.map((v, i) => (
        <div class={`tiktok-card js-reveal`} style={`animation-delay:${i * 0.15 + 0.1}s`}>
          <div class="tiktok-badge">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.8a8.18 8.18 0 004.78 1.52V6.88a4.85 4.85 0 01-1.01-.19z"/></svg>
            TikTok
          </div>
          <div class="tiktok-frame-wrap">
            <iframe
              src={`https://www.tiktok.com/embed/v2/${v.id}?lang=uk-UA`}
              title={v.caption}
              allow="autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              loading="lazy"
            ></iframe>
          </div>
          <div class="tiktok-caption">{v.caption}</div>
          <a href={`https://www.tiktok.com/@mad__dentist/video/${v.id}`} target="_blank" rel="noopener noreferrer" class="tiktok-cta">
            {t.tiktokCta} →
          </a>
        </div>
      ))}

      {/* Instagram card */}
      <div class="ig-card js-reveal" style="animation-delay:0.4s">
        <div class="ig-top">
          <div class="ig-avatar" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
          </div>
          <div class="ig-handle-wrap">
            <div class="ig-handle">{t.igHandle}</div>
            <div class="ig-platform">Instagram</div>
          </div>
        </div>

        <div class="ig-stats">
          <div class="ig-stat">
            <span class="ig-stat-n">{t.igFollowers}</span>
            <span class="ig-stat-l">{t.igFollowersLabel}</span>
          </div>
          <div class="ig-stat-divider"></div>
          <div class="ig-stat">
            <span class="ig-stat-n">{t.igPosts}</span>
            <span class="ig-stat-l">{t.igPostsLabel}</span>
          </div>
        </div>

        <p class="ig-bio">{t.igBio}</p>

        {/* Recent content teasers — static, scraped */}
        <div class="ig-posts">
          {[
            { emoji: '🦷', text: 'Керамічні вініри — окремий вид мистецтва' },
            { emoji: '✨', text: 'Композитна реставрація за 1 візит' },
            { emoji: '😍', text: 'Коронки з цирконію + вініри — 2.5 роки тому' },
          ].map(p => (
            <div class="ig-post-teaser">
              <span class="ig-post-emoji">{p.emoji}</span>
              <span class="ig-post-text">{p.text}</span>
            </div>
          ))}
        </div>

        <a href={IG_URL} target="_blank" rel="noopener noreferrer" class="ig-cta">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
          {t.igCta}
        </a>

        <a href={TIKTOK_PROFILE} target="_blank" rel="noopener noreferrer" class="tiktok-profile-cta">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.8a8.18 8.18 0 004.78 1.52V6.88a4.85 4.85 0 01-1.01-.19z"/></svg>
          TikTok @mad__dentist
        </a>
      </div>

    </div>
  </div>
</section>

<style>
.social-section { background: var(--cream); padding: 6rem 0; }

.social-header { text-align: center; margin-bottom: 52px; }
.social-h2 { font-family: var(--serif); font-size: clamp(26px,3.5vw,44px); font-weight: 300; color: var(--forest); }
.social-h2 em { font-style: italic; color: var(--rose); }
.social-sub { color: var(--text-mid); font-size: 14px; margin-top: 12px; max-width: 480px; margin-inline: auto; line-height: 1.7; }

.social-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 24px;
  align-items: start;
}

/* ── TikTok cards ──────────────────────────────── */
.tiktok-card {
  display: flex; flex-direction: column; gap: 14px;
  background: var(--forest);
  border-radius: 4px; overflow: hidden;
  padding: 0 0 20px;
}
.tiktok-badge {
  display: flex; align-items: center; gap: 7px;
  padding: 12px 16px 0;
  font-size: 10px; font-weight: 500; letter-spacing: .14em; text-transform: uppercase;
  color: rgba(255,255,255,.45);
}
.tiktok-frame-wrap {
  position: relative; width: 100%; aspect-ratio: 9/16;
  overflow: hidden; background: #0a0a0a;
}
.tiktok-frame-wrap iframe {
  position: absolute; inset: 0; width: 100%; height: 100%;
  border: none;
}
.tiktok-caption {
  padding: 0 16px;
  font-size: 12px; color: rgba(255,255,255,.65); line-height: 1.5;
}
.tiktok-cta {
  margin: 0 16px;
  font-size: 10px; font-weight: 500; letter-spacing: .12em; text-transform: uppercase;
  color: var(--gold); text-decoration: none;
  display: inline-flex; align-items: center; gap: 6px;
  transition: color .2s;
}
.tiktok-cta:hover { color: var(--gold-light); }

/* ── Instagram card ──────────────────────────────── */
.ig-card {
  display: flex; flex-direction: column; gap: 20px;
  background: var(--cream-dark); border-radius: 4px;
  padding: 28px 24px; border: 1px solid rgba(196,64,110,.12);
}
.ig-top { display: flex; align-items: center; gap: 14px; }
.ig-avatar {
  width: 48px; height: 48px; border-radius: 50%;
  background: linear-gradient(135deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888);
  display: flex; align-items: center; justify-content: center; color: #fff; flex-shrink: 0;
}
.ig-handle { font-family: var(--sans); font-size: 15px; font-weight: 500; color: var(--forest); }
.ig-platform { font-size: 10px; color: var(--text-light); letter-spacing: .1em; text-transform: uppercase; margin-top: 2px; }

.ig-stats {
  display: flex; align-items: center; gap: 0;
  background: var(--cream); border-radius: 2px; padding: 14px 0;
}
.ig-stat { flex: 1; text-align: center; }
.ig-stat-divider { width: 1px; height: 32px; background: rgba(200,169,110,.2); }
.ig-stat-n { display: block; font-family: var(--serif); font-size: 22px; font-weight: 300; color: var(--forest); }
.ig-stat-l { display: block; font-size: 9px; color: var(--text-light); letter-spacing: .12em; text-transform: uppercase; margin-top: 3px; }

.ig-bio { font-size: 13px; color: var(--text-mid); line-height: 1.7; }

.ig-posts { display: flex; flex-direction: column; gap: 10px; }
.ig-post-teaser {
  display: flex; align-items: flex-start; gap: 10px;
  padding: 10px 12px; background: var(--cream); border-radius: 2px;
  border-left: 2px solid var(--rose-pale);
}
.ig-post-emoji { font-size: 16px; flex-shrink: 0; line-height: 1.3; }
.ig-post-text { font-size: 12px; color: var(--text-mid); line-height: 1.5; }

.ig-cta {
  display: flex; align-items: center; justify-content: center; gap: 8px;
  background: linear-gradient(135deg, #f09433 0%, #e6683c 25%, #dc2743 50%, #cc2366 75%, #bc1888 100%);
  color: #fff; text-decoration: none;
  font-size: 11px; font-weight: 500; letter-spacing: .1em; text-transform: uppercase;
  padding: 13px 20px; border-radius: 2px;
  transition: opacity .2s;
}
.ig-cta:hover { opacity: .9; }

.tiktok-profile-cta {
  display: flex; align-items: center; justify-content: center; gap: 8px;
  background: #0a0a0a; color: #f0f0f0; text-decoration: none;
  font-size: 11px; font-weight: 500; letter-spacing: .1em; text-transform: uppercase;
  padding: 12px 20px; border-radius: 2px;
  transition: background .2s;
}
.tiktok-profile-cta:hover { background: #1a1a1a; }

/* ── Responsive ──────────────────────────────────── */
@media (max-width: 1024px) {
  .social-grid { grid-template-columns: 1fr 1fr; }
  .ig-card { grid-column: 1 / -1; max-width: 480px; margin: 0 auto; width: 100%; }
}
@media (max-width: 640px) {
  .social-grid { grid-template-columns: 1fr; }
  .ig-card { grid-column: auto; max-width: 100%; }
}
</style>
