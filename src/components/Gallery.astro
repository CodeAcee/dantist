---
interface Props { t: { eyebrow: string; h2: string; h2em: string; cells: string[] } }
const { t } = Astro.props;
---
<section class="gallery-section" id="gallery" aria-label="Gallery">
  <div class="section-inner">
    <div class="gallery-header">
      <div class="eyebrow">{t.eyebrow}</div>
      <h2 class="gallery-h2">{t.h2}<em>{t.h2em}</em></h2>
    </div>
    <div class="gallery-grid">
      {t.cells.map((label, i) => (
        <div class={`gallery-cell${i === 0 ? ' gallery-cell--tall' : ''} js-reveal`} style={`animation-delay:${i*0.1}s`}>
          <div class="img-slot" style="height:100%;border-radius:2px">{label}</div>
        </div>
      ))}
    </div>
  </div>
</section>
<style>
.gallery-section { background: var(--cream-dark); padding: 6rem 0; }
.gallery-header  { text-align: center; margin-bottom: 48px; }
.gallery-h2 { font-family: var(--serif); font-size: clamp(26px,3.5vw,44px); font-weight: 300; color: var(--forest); }
.gallery-h2 em { font-style: italic; }
.gallery-grid { display: grid; grid-template-columns: 2fr 1fr 1fr; grid-template-rows: 280px 240px; gap: 12px; }
.gallery-cell--tall { grid-row: 1/3; }
@media (max-width: 768px) { .gallery-grid { grid-template-columns: 1fr 1fr; grid-template-rows: repeat(3,200px); } .gallery-cell--tall { grid-row: auto; } }
@media (max-width: 480px) { .gallery-grid { grid-template-columns: 1fr; grid-template-rows: repeat(5,180px); } }
</style>
