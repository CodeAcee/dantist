---
import type { T } from '../i18n/translations';
interface Props { t: T }
const { t } = Astro.props;

const hrefs = ['#services','#gallery','#results','#about','#reviews','#prices','#contact'];
---
<nav id="main-nav" class="nav">
  <div class="nav-logo-row">
    <div class="nav-line"></div>
    <div class="nav-brand">
      <a href="#" class="brand-name">
        {t.brand.name} <em>{t.brand.accent}</em>
        <span class="brand-sub">{t.brand.sub}</span>
      </a>
      <div class="brand-tagline">{t.brand.tagline}</div>
    </div>
    <div class="nav-line nav-line--right"></div>
    <button class="hamburger" id="hamburger" aria-label="Menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>

  <div class="nav-links-row" id="nav-links">
    {t.nav.map((label: string, i: number) => (
      <a href={hrefs[i]} class="nav-link">{label}</a>
    ))}

    <!-- Language switcher -->
    <a href={t.langSwitch.href} class="lang-switch" aria-label="Switch language">
      {t.langSwitch.label}
    </a>

    <!-- Modern Mode toggle -->
    <button id="modern-mode-btn" class="modern-mode-btn" aria-label="Switch to Modern Mode">
      ◆ Modern
    </button>
  </div>
</nav>

<script>
const nav  = document.getElementById('main-nav')!;
const btn  = document.getElementById('hamburger')!;
const menu = document.getElementById('nav-links')!;

window.addEventListener('scroll', () => {
  nav.classList.toggle('nav--scrolled', window.scrollY > 60);
}, { passive: true });

btn.addEventListener('click', () => {
  const open = menu.classList.toggle('nav-links-row--open');
  btn.setAttribute('aria-expanded', String(open));
  btn.classList.toggle('hamburger--open', open);
});

menu.querySelectorAll('a').forEach(a => {
  a.addEventListener('click', () => {
    menu.classList.remove('nav-links-row--open');
    btn.setAttribute('aria-expanded', 'false');
    btn.classList.remove('hamburger--open');
  });
});

document.getElementById('modern-mode-btn')!.addEventListener('click', () => {
  window.dispatchEvent(new CustomEvent('zoomer:open'));
});
</script>

<style>
.nav {
  position: sticky; top: 0; z-index: 100;
  background: var(--cream);
  border-bottom: 1px solid rgba(200,169,110,.15);
  transition: background .3s, box-shadow .3s;
}
.nav--scrolled {
  background: rgba(245,240,232,.95);
  backdrop-filter: blur(12px);
  border-bottom-color: rgba(200,169,110,.25);
  box-shadow: 0 2px 20px rgba(42,61,46,.06);
}
.nav-logo-row {
  display: flex; justify-content: center; align-items: center;
  padding: 14px var(--px) 0; gap: 2rem;
}
.nav-line { flex: 1; height: 1px; background: linear-gradient(90deg,transparent,rgba(200,169,110,.35)); }
.nav-line--right { background: linear-gradient(90deg,rgba(200,169,110,.35),transparent); }
.nav-brand { text-align: center; }
.brand-name {
  font-family: var(--serif); font-size: 26px; font-weight: 300;
  letter-spacing: .05em; color: var(--forest); text-decoration: none; display: block;
}
.brand-name em { font-style: italic; color: var(--gold); }
.brand-sub { font-size: 14px; font-weight: 300; color: var(--text-light); font-style: italic; margin-left: 8px; }
.brand-tagline { font-size: 8px; letter-spacing: .22em; text-transform: uppercase; color: var(--text-light); margin-top: 3px; padding-bottom: 10px; }

.nav-links-row {
  display: flex; justify-content: center; align-items: center;
  border-top: 1px solid rgba(200,169,110,.1); flex-wrap: wrap;
}
.nav-link {
  font-size: 10px; font-weight: 400; letter-spacing: .18em;
  text-transform: uppercase; color: var(--text-mid); text-decoration: none;
  padding: 13px 18px; position: relative; transition: color .2s; white-space: nowrap;
}
.nav-link:hover { color: var(--forest); }
.nav-link::after {
  content: ''; position: absolute; bottom: 0; left: 18px; right: 18px;
  height: 1.5px; background: var(--gold);
  transform: scaleX(0); transform-origin: left; transition: transform .25s ease;
}
.nav-link:hover::after { transform: scaleX(1); }

/* ── Language switcher ───────────────────── */
.lang-switch {
  margin-left: 8px;
  font-size: 9px; font-weight: 500; letter-spacing: .2em; text-transform: uppercase;
  color: var(--forest); text-decoration: none;
  padding: 5px 12px;
  border: 1px solid rgba(200,169,110,.45);
  border-radius: 2px;
  transition: all .2s;
  white-space: nowrap;
  align-self: center;
}
.lang-switch:hover {
  background: var(--gold);
  border-color: var(--gold);
  color: var(--forest);
}

/* ── Modern Mode button ─────────────────── */
.modern-mode-btn {
  margin-left: 8px;
  font-family: var(--sans); font-size: 9px; font-weight: 500;
  letter-spacing: .18em; text-transform: uppercase;
  color: var(--cream); background: var(--forest);
  border: 1px solid var(--forest); border-radius: 2px;
  padding: 5px 12px; cursor: pointer;
  transition: all .2s; white-space: nowrap;
  align-self: center;
}
.modern-mode-btn:hover {
  background: #0a0a0a;
  border-color: #c8ff00;
  color: #c8ff00;
}

/* ── Hamburger ───────────────────────────── */
.hamburger { display: none; flex-direction: column; gap: 5px; background: none; border: none; cursor: pointer; padding: 6px; margin-left: auto; }
.hamburger span { display: block; width: 22px; height: 1.5px; background: var(--forest); transition: all .3s; transform-origin: center; }
.hamburger--open span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
.hamburger--open span:nth-child(2) { opacity: 0; }
.hamburger--open span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

@media (max-width: 768px) {
  .hamburger { display: flex; }
  .nav-line   { display: none; }
  .brand-name { font-size: 22px; }
  .nav-links-row { flex-direction: column; align-items: flex-start; border-top: none; max-height: 0; overflow: hidden; transition: max-height .4s cubic-bezier(.16,1,.3,1); }
  .nav-links-row--open { max-height: 480px; border-top: 1px solid rgba(200,169,110,.1); }
  .nav-link { padding: 12px var(--px); width: 100%; }
  .lang-switch { margin: 8px var(--px) 12px; }
}
</style>
