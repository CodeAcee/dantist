---
<div class="announcement-bar">
  <div class="ann-left">
    <span>Дніпро, просп. Яворницького 22</span>
    <span class="sep"></span>
    <span>Пн–Пт 9–20 / Сб 10–18</span>
  </div>
  <div class="ann-right">
    <span class="dot"></span>
    Безкоштовна консультація
  </div>
</div>

<style>
.announcement-bar {
  background: var(--forest);
  padding: 7px var(--px);
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 8px;
}
.ann-left {
  display: flex;
  align-items: center;
  gap: 1.2rem;
  font-size: 11px;
  letter-spacing: .06em;
  color: rgba(245,240,232,.42);
}
.sep {
  display: block;
  width: 1px;
  height: 10px;
  background: rgba(245,240,232,.12);
}
.ann-right {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 11px;
  letter-spacing: .1em;
  color: var(--gold-light);
}
.dot {
  width: 5px;
  height: 5px;
  border-radius: 50%;
  background: var(--gold);
  animation: pulse 2s infinite;
}
</style>
