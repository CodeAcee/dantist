---
import SplitText    from './animations/SplitText';
import BlurText     from './animations/BlurText';
import GradientText from './animations/GradientText';
import CountUp      from './animations/CountUp';
import BeamsBg      from './backgrounds/BeamsBg';
import type { T }  from '../i18n/translations';
interface Props { t: T }
const { t } = Astro.props;
const h = t.hero;
const stats = [
  { end: 2400, suffix: '+', label: h.stats[0] },
  { end: 14,   suffix: '',  label: h.stats[1] },
  { end: 98,   suffix: '%', label: h.stats[2] },
];
---
<section class="hero" aria-label="Hero">
  <div class="hero-text">
    <div class="hero-eyebrow">
      <span class="eyebrow">{h.eyebrow}</span>
    </div>
    <h1 class="hero-h1">
      <SplitText client:load delay={0.2}>{h.h1[0]}</SplitText><br/>
      <SplitText client:load delay={0.55} style={{ fontStyle:'italic', color:'#c8a96e' }}>{h.h1[1]}</SplitText>
      <SplitText client:load delay={0.75}>{h.h1[2]}</SplitText><br/>
      <SplitText client:load delay={0.95}>{h.h1[3]}</SplitText>
    </h1>
    <p class="hero-sub">
      <BlurText client:load delay={0.8}>{h.sub}</BlurText>
    </p>
    <div class="hero-cta">
      <a href="#contact" class="btn-primary">{h.cta}</a>
      <a href="#results" class="btn-ghost">{h.ctaGhost}</a>
    </div>
    <div class="hero-stats">
      {stats.map(s => (
        <div class="stat">
          <div class="stat-num">
            <GradientText client:load>
              <CountUp client:visible end={s.end} suffix={s.suffix} />
            </GradientText>
          </div>
          <div class="stat-label">{s.label}</div>
        </div>
      ))}
    </div>
  </div>

  <div class="hero-image" aria-hidden="true">
    <div class="hero-image-bg"></div>
    <div class="hero-image-overlay"></div>
    <BeamsBg client:visible />
    <div class="img-slot hero-img-slot">Dr. Chirkova — warm light, shallow DoF</div>
    <div class="hero-badge-free">{h.badge}</div>
    <div class="hero-card">
      <div class="hero-card-role">{h.cardRole}</div>
      <div class="hero-card-name">Dr. Chirkova</div>
      <div class="hero-card-title">{h.cardTitle}</div>
      <div class="hero-card-stars">★★★★★</div>
    </div>
  </div>
</section>

<style>
.hero { min-height: 88vh; display: grid; grid-template-columns: 1fr 1fr; background: var(--cream); }
.hero-text { padding: 6rem 3rem 5rem 5rem; display: flex; flex-direction: column; justify-content: center; }
.hero-eyebrow { animation: fadeUp .6s .1s both; }
.hero-h1 { font-family: var(--serif); font-size: clamp(36px,5vw,62px); font-weight: 300; line-height: 1.02; color: var(--forest); margin-bottom: 24px; letter-spacing: -.01em; }
.hero-sub { font-size: 15px; line-height: 1.75; max-width: 420px; margin-bottom: 36px; color: var(--text-mid); }
.hero-cta { display: flex; gap: 14px; align-items: center; flex-wrap: wrap; animation: fadeUp .7s 1.2s both; }
.btn-primary { background: var(--forest); color: var(--cream); font-family: var(--sans); font-size: 12px; font-weight: 500; letter-spacing: .08em; text-transform: uppercase; padding: 15px 30px; border-radius: 2px; transition: background .2s, transform .2s; display: inline-block; }
.btn-primary:hover { background: var(--forest-mid); transform: translateY(-1px); }
.btn-ghost { font-size: 13px; color: var(--forest); display: flex; align-items: center; gap: 8px; transition: gap .2s; }
.btn-ghost:hover { gap: 12px; }
.hero-stats { margin-top: 56px; display: flex; gap: 48px; padding-top: 32px; border-top: 1px solid rgba(200,169,110,.2); animation: fadeUp .7s 1.4s both; flex-wrap: wrap; }
.stat-num { font-family: var(--serif); font-size: 40px; font-weight: 300; line-height: 1; }
.stat-label { font-size: 10px; color: var(--text-light); letter-spacing: .08em; text-transform: uppercase; margin-top: 6px; }
.hero-image { position: relative; overflow: hidden; min-height: 400px; }
.hero-image-bg { position: absolute; inset: 0; background: linear-gradient(135deg,var(--forest) 0%,var(--forest-mid) 50%,#4a6b4f 100%); }
.hero-image-overlay { position: absolute; inset: 0; background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none'%3E%3Cg fill='%23fff' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E"); }
.hero-img-slot { position: absolute; inset: 0; background: transparent; color: rgba(245,240,232,.4); }
.hero-badge-free { position: absolute; top: 32px; right: 32px; background: rgba(200,169,110,.12); border: 1px solid rgba(200,169,110,.3); border-radius: 2px; padding: 8px 14px; font-size: 10px; color: var(--gold-light); letter-spacing: .12em; text-transform: uppercase; backdrop-filter: blur(8px); animation: fadeUp .5s 1s both; }
.hero-card { position: absolute; bottom: 48px; left: -24px; background: var(--cream); border-radius: 4px; padding: 20px 24px; min-width: 240px; box-shadow: 0 20px 60px rgba(0,0,0,.15); animation: fadeUp .6s 1.5s both; z-index: 2; }
.hero-card-role  { font-size: 9px; letter-spacing: .14em; text-transform: uppercase; color: var(--text-light); margin-bottom: 6px; }
.hero-card-name  { font-family: var(--serif); font-size: 18px; color: var(--forest); }
.hero-card-title { font-size: 12px; color: var(--text-mid); margin-top: 2px; }
.hero-card-stars { color: var(--gold); font-size: 12px; margin-top: 8px; letter-spacing: 2px; }
@media (max-width: 900px) { .hero { grid-template-columns: 1fr; } .hero-text { padding: 4rem var(--px) 3rem; } .hero-image { min-height: 320px; } .hero-card { left: 16px; bottom: 16px; min-width: 200px; } }
@media (max-width: 480px) { .hero-stats { gap: 28px; } .hero-h1 { font-size: 34px; } }
</style>
