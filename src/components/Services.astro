---
import ServicesList from './ServicesList';
interface Service { name: string; desc: string; img: string }
interface Props {
  t: { eyebrow: string; h2a: string; h2em: string; h2b: string; list: Service[] };
  locale: string;
}
const { t, locale } = Astro.props;
---
<section class="services-section" id="services" aria-label="Services">
  <div class="section-inner">
    <div class="services-header js-reveal">
      <div>
        <div class="eyebrow">{t.eyebrow}</div>
        <h2 class="services-h2">{t.h2a}<em>{t.h2em}</em>{t.h2b}</h2>
      </div>
    </div>
    <ServicesList client:visible locale={locale} fallback={t.list} />
  </div>
</section>
<style>
.services-section { background: var(--cream); padding: 7rem 0; }
.services-header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 56px; }
.services-h2 { font-family: var(--serif); font-size: clamp(28px,4vw,48px); font-weight: 300; color: var(--forest); line-height: 1.08; white-space: pre-line; }
.services-h2 em { font-style: italic; background: linear-gradient(120deg,var(--forest) 40%,var(--gold) 50%,var(--forest) 60%); background-size: 200% auto; -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; animation: shimmer 3s linear infinite; }
.services-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 1px; background: rgba(200,169,110,.2); }
.service-card { background: var(--cream); cursor: pointer; overflow: hidden; transition: background .4s cubic-bezier(.16,1,.3,1); }
.service-card:hover { background: var(--forest); }
.svc-img { height: 160px; border-radius: 0; }
.svc-body { padding: 20px 24px 24px; }
.svc-num { font-family: var(--serif); font-size: 38px; font-weight: 300; color: rgba(42,61,46,.06); line-height: 1; margin-bottom: 10px; transition: color .3s; }
.service-card:hover .svc-num { color: rgba(245,240,232,.06); }
.svc-name { font-family: var(--serif); font-size: 20px; font-weight: 400; color: var(--forest); margin-bottom: 8px; line-height: 1.2; transition: color .3s; }
.service-card:hover .svc-name { color: var(--cream); }
.svc-desc { font-size: 12px; color: var(--text-mid); line-height: 1.6; transition: color .3s; }
.service-card:hover .svc-desc { color: rgba(245,240,232,.6); }
.svc-arrow { font-size: 16px; color: var(--gold); margin-top: 14px; transition: transform .2s; }
.service-card:hover .svc-arrow { transform: translateX(4px); }
@media (max-width: 900px) { .services-grid { grid-template-columns: repeat(2,1fr); } }
@media (max-width: 580px) { .services-grid { grid-template-columns: 1fr; } }
</style>
