---
import '../styles/global.css';
import ZoomerMode from '../components/ZoomerMode';
import SiteLoader from '../components/SiteLoader';
interface Props {
  title?: string;
  description?: string;
  keywords?: string;
  image?: string;
  lang?: string;
  ogLocale?: string;
}
const {
  title = 'Chirkova Dentist — Косметична стоматологія у Дніпрі',
  description = 'Бутикова стоматологія у Дніпрі. Вініри, імпланти, елайнери, відбілювання. Перша консультація безкоштовно.',
  keywords = 'стоматолог Дніпро, дантист Дніпро, імплантація зубів Дніпро, Чиркова Валерія, вініри, відбілювання зубів, чистка зубів, лікування карієсу',
  image = '/og-image.png',
  lang = 'uk',
  ogLocale = 'uk_UA',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL(image, Astro.site);
---
<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="theme-color" content="#0a0a0a" />
  <link rel="canonical" href={canonical} />

  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="keywords" content={keywords} />
  <meta name="robots" content="index, follow, max-image-preview:large" />
  <meta name="author" content="Чиркова Валерія — Chirkova Dentist" />

  <!-- Local SEO -->
  <meta name="geo.region" content="UA-12" />
  <meta name="geo.placename" content="Дніпро" />

  <!-- Alternate language links -->
  <link rel="alternate" hreflang="uk" href={new URL('/', Astro.site)} />
  <link rel="alternate" hreflang="en" href={new URL('/en/', Astro.site)} />
  <link rel="alternate" hreflang="x-default" href={new URL('/', Astro.site)} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Chirkova Dentist" />
  <meta property="og:locale" content={ogLocale} />
  <meta property="og:locale:alternate" content={ogLocale === 'uk_UA' ? 'en_US' : 'uk_UA'} />
  <meta property="og:url" content={canonical} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- LocalBusiness Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Dentist",
    "@id": "https://chirkovadentist.com/#clinic",
    "name": "Chirkova Dentist Studio",
    "alternateName": "Стоматологія Чиркова Валерія",
    "description": description,
    "url": "https://chirkovadentist.com",
    "telephone": "+380561234567",
    "email": "lerchiiik18@gmail.com",
    "image": ogImage.href,
    "logo": new URL('/favicon.svg', Astro.site).href,
    "founder": {
      "@type": "Person",
      "name": "Чиркова Валерія",
      "alternateName": "Chirkova Valeria",
      "jobTitle": "Лікар-стоматолог"
    },
    "medicalSpecialty": "Dentistry",
    "foundingDate": "2011",
    "priceRange": "$$",
    "currenciesAccepted": "UAH",
    "knowsLanguage": ["uk", "ru", "en"],
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "просп. Яворницького 22",
      "addressLocality": "Дніпро",
      "addressRegion": "Дніпропетровська область",
      "addressCountry": "UA"
    },
    "areaServed": { "@type": "City", "name": "Дніпро" },
    "availableService": [
      { "@type": "MedicalProcedure", "name": "Імплантація зубів" },
      { "@type": "MedicalProcedure", "name": "Вініри та естетична реставрація" },
      { "@type": "MedicalProcedure", "name": "Відбілювання зубів" },
      { "@type": "MedicalProcedure", "name": "Елайнери та брекет-системи" },
      { "@type": "MedicalProcedure", "name": "Професійна чистка зубів" },
      { "@type": "MedicalProcedure", "name": "Лікування карієсу та терапія" }
    ],
    "openingHoursSpecification": [
      { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"], "opens": "09:00", "closes": "20:00" },
      { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Saturday"], "opens": "10:00", "closes": "18:00" }
    ],
    "sameAs": [
      "https://www.instagram.com/mad__dentist/",
      "https://www.tiktok.com/@mad__dentist"
    ]
  })} />
</head>
<body>
  <SiteLoader client:load />
  <slot />
  <ZoomerMode client:load />
</body>
</html>
