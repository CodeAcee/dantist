---
import '../styles/global.css';
import SeoHead from '../components/SeoHead.astro';
import ZoomerMode from '../components/ZoomerMode';
import SiteLoader from '../components/SiteLoader';
interface Props {
  title?: string;
  description?: string;
  keywords?: string;
  image?: string;
  lang?: string;
  ogLocale?: string;
}
const {
  title = 'Chirkova Dentist — Косметична стоматологія у Дніпрі',
  description = 'Cтоматологія у Дніпрі. Вініри, імпланти, елайнери, відбілювання. Перша консультація безкоштовно.',
  keywords,
  image,
  lang = 'uk',
  ogLocale = 'uk_UA',
} = Astro.props;
---
<!DOCTYPE html>
<html lang={lang}>
<head>
  <SeoHead
    title={title}
    description={description}
    keywords={keywords}
    image={image}
    lang={lang}
    ogLocale={ogLocale}
  />
</head>
<body>
  <SiteLoader client:load />
  <slot />
  <ZoomerMode client:load lang={lang === 'en' ? 'en' : 'uk'} />
</body>
</html>
