---
import '../styles/global.css';
import ZoomerMode from '../components/ZoomerMode';
import SiteLoader from '../components/SiteLoader';
interface Props {
  title?: string;
  description?: string;
  image?: string;
  lang?: string;
}
const {
  title = 'Chirkova Dentist — Косметична стоматологія у Дніпрі',
  description = 'Бутикова стоматологія у Дніпрі. Вініри, імпланти, елайнери, відбілювання. Перша консультація безкоштовно.',
  image = '/og-image.jpg',
  lang = 'uk',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
---
<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="theme-color" content="#2a3d2e" />
  <link rel="canonical" href={canonical} />

  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content="index, follow" />

  <!-- Alternate language links -->
  <link rel="alternate" hreflang="uk" href={new URL('/dantist/', Astro.site)} />
  <link rel="alternate" hreflang="en" href={new URL('/dantist/en/', Astro.site)} />
  <link rel="alternate" hreflang="x-default" href={new URL('/dantist/', Astro.site)} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonical} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={new URL(image, Astro.site)} />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/dantist/favicon.svg" />

  <!-- LocalBusiness Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Dentist",
    "name": "Chirkova Dentist Studio",
    "description": description,
    "url": "https://codeacee.github.io/dantist",
    "telephone": "+380561234567",
    "email": "hello@chirkovadentist.ua",
    "foundingDate": "2011",
    "priceRange": "$$",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "просп. Яворницького 22",
      "addressLocality": "Дніпро",
      "addressCountry": "UA"
    },
    "openingHoursSpecification": [
      { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"], "opens": "09:00", "closes": "20:00" },
      { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Saturday"], "opens": "10:00", "closes": "18:00" }
    ],
    "sameAs": [
      "https://www.instagram.com/chirkovadentist",
      "https://www.tiktok.com/@chirkovadentist"
    ],
    "aggregateRating": { "@type": "AggregateRating", "ratingValue": "5", "reviewCount": "127" }
  })} />
</head>
<body>
  <SiteLoader client:load />
  <slot />
  <ZoomerMode client:load />
</body>
</html>
