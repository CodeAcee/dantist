---
import PageLayout from "../../layouts/PageLayout.astro";
import ServiceArticle from "../../components/ServiceArticle.astro";
import { SERVICES, serviceSchema, type Service } from "../../i18n/services";

export function getStaticPaths() {
  return SERVICES.map((s) => ({ params: { service: s.slug }, props: { service: s } }));
}

const { service } = Astro.props as { service: Service };
const base = import.meta.env.BASE_URL.replace(/\/?$/, "/");
const t = service.en;
const extraSchema = serviceSchema(service, "en", Astro.site!.href, base);
---
<PageLayout
  title={t.metaTitle}
  description={t.metaDescription}
  keywords={t.keywords}
  lang="en"
  ogLocale="en_US"
  extraSchema={extraSchema}
>
  <ServiceArticle service={service} lang="en" base={base} />
</PageLayout>
