---
import { translations } from '../../i18n/translations';
import Layout        from '../../layouts/Layout.astro';
import Nav           from '../../components/Nav.astro';
import Footer        from '../../components/Footer.astro';
import ReviewsList   from '../../components/ReviewsList';

const t = translations.en;
const fallback = t.reviews.list.map((r: any) => ({
  quote: r.q, name: r.n, since: r.s, bg: r.bg, color: r.c, initials: r.ini,
}));

const GOOGLE_REVIEWS = [
  { name: 'Maria V.',    stars: 5, text: 'Best clinic in Dnipro! Veneers done in 2 weeks — results exceeded all expectations. Dr. Chirkova is a true master.', ago: '2 weeks ago' },
  { name: 'Dmytro K.',   stars: 5, text: 'The doctor is very attentive and never rushes. For the first time in my life I was not afraid to go to the dentist!', ago: '1 month ago' },
  { name: 'Iryna S.',    stars: 5, text: 'Got an implant — I even forgot where it is. Thank you to the whole team for the care and support at every step.', ago: '2 months ago' },
  { name: 'Oleh N.',     stars: 5, text: 'Zoom whitening — 8 shades in one session. No pain at all, very comfortable. Results have lasted 4 months so far.', ago: '3 months ago' },
  { name: 'Tetyana R.',  stars: 5, text: 'Came for a free consultation — very thorough and detailed. Got aligners. Teeth are straight, smile is a dream!', ago: '4 months ago' },
  { name: 'Vasyl M.',    stars: 5, text: 'Fast, quality work with no extra stress. The doctor explains every step. The coffee is great too!', ago: '5 months ago' },
];
---
<Layout title="Reviews — Chirkova Dentist" description="Patient reviews of Chirkova Dentist Studio. Real opinions on veneers, implants, aligners and dental care in Dnipro." lang="en">
  <Nav t={t} />

  <main>
    <section class="reviews-hero">
      <div class="section-inner">
        <div class="rh-eyebrow">Patient voices</div>
        <h1 class="rh-h1">What they <em>say</em></h1>
        <p class="rh-sub">Real reviews from real people. No filters — no staging.</p>
        <div class="rh-rating">
          <span class="rh-score">4.9</span>
          <div>
            <div class="rh-stars">★★★★★</div>
            <div class="rh-count">127+ reviews · Google Maps</div>
          </div>
        </div>
      </div>
    </section>

    <section class="reviews-section" style="padding-top: 0">
      <div class="section-inner">
        <div class="block-label">Patient reviews</div>
        <ReviewsList client:visible locale="en" sinceLabel="Patient since" fallback={fallback} />
      </div>
    </section>

    <section class="google-section">
      <div class="section-inner">
        <div class="g-header">
          <div>
            <div class="block-label">Google Maps</div>
            <h2 class="g-h2">Reviews on <em>Google</em></h2>
          </div>
          <a href="https://maps.google.com/?q=Yavornytskogo+Ave+22,+Dnipro" target="_blank" rel="noopener noreferrer" class="g-link">View on Google →</a>
        </div>
        <div class="g-grid">
          {GOOGLE_REVIEWS.map(r => (
            <article class="g-card">
              <div class="g-card-top">
                <div class="g-avatar">G</div>
                <div>
                  <div class="g-name">{r.name}</div>
                  <div class="g-ago">{r.ago}</div>
                </div>
                <div class="g-stars">{'★'.repeat(r.stars)}</div>
              </div>
              <p class="g-text">"{r.text}"</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="reviews-cta">
      <div class="section-inner">
        <h2 class="cta-h2">Become the <em>next one</em></h2>
        <p class="cta-sub">Free first consultation. No obligations.</p>
        <a href="/dantist/en/#contact" class="btn-primary">Book now →</a>
      </div>
    </section>
  </main>

  <Footer t={t.footer} brand={t.brand} />
</Layout>

<style>
.reviews-hero { background: var(--cream); padding: 6rem 0 4rem; border-bottom: 1px solid rgba(200,169,110,.15); }
.rh-eyebrow  { font-size: 9px; letter-spacing: .22em; text-transform: uppercase; color: var(--gold); margin-bottom: 14px; }
.rh-h1       { font-family: var(--serif); font-size: clamp(36px,5vw,64px); font-weight: 300; color: var(--forest); line-height: 1.05; margin-bottom: 16px; }
.rh-h1 em    { font-style: italic; color: var(--rose); }
.rh-sub      { font-size: 15px; color: var(--text-mid); max-width: 480px; line-height: 1.7; margin-bottom: 32px; }
.rh-rating   { display: flex; align-items: center; gap: 16px; }
.rh-score    { font-family: var(--serif); font-size: 56px; font-weight: 300; color: var(--forest); line-height: 1; }
.rh-stars    { color: var(--gold); font-size: 18px; letter-spacing: 3px; margin-bottom: 3px; }
.rh-count    { font-size: 11px; color: var(--text-light); letter-spacing: .05em; }
.block-label { font-size: 9px; letter-spacing: .22em; text-transform: uppercase; color: var(--text-light); margin-bottom: 32px; padding-top: 5rem; }
.reviews-section { background: var(--cream); padding-bottom: 5rem; }
.google-section { background: #fff; padding: 5rem 0 6rem; }
.g-header  { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 40px; flex-wrap: wrap; gap: 16px; }
.g-h2      { font-family: var(--serif); font-size: clamp(24px,3vw,38px); font-weight: 300; color: var(--forest); }
.g-h2 em   { font-style: italic; color: var(--rose); }
.g-link    { font-size: 12px; color: var(--forest); text-decoration: none; border-bottom: 1px solid rgba(42,61,46,.2); padding-bottom: 1px; transition: border-color .2s; white-space: nowrap; }
.g-link:hover { border-color: var(--forest); }
.g-grid    { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px,1fr)); gap: 20px; }
.g-card    { background: var(--cream); border-radius: 4px; padding: 24px; border: 1px solid rgba(201,168,124,.12); }
.g-card-top { display: flex; align-items: flex-start; gap: 12px; margin-bottom: 14px; }
.g-avatar  { width: 36px; height: 36px; border-radius: 50%; flex-shrink: 0; background: conic-gradient(#4285f4 0 25%,#ea4335 25% 50%,#fbbc05 50% 75%,#34a853 75%); display: flex; align-items: center; justify-content: center; font-size: 13px; font-weight: 700; color: #fff; }
.g-name  { font-size: 13px; font-weight: 500; color: var(--text-dark); }
.g-ago   { font-size: 10px; color: var(--text-light); margin-top: 2px; }
.g-stars { margin-left: auto; color: var(--gold); font-size: 12px; letter-spacing: 1px; white-space: nowrap; }
.g-text  { font-family: var(--serif); font-size: 15px; font-style: italic; color: var(--text-mid); line-height: 1.65; }
.reviews-cta { background: var(--forest); padding: 6rem 0; text-align: center; }
.cta-h2      { font-family: var(--serif); font-size: clamp(28px,4vw,48px); font-weight: 300; color: var(--cream); margin-bottom: 12px; }
.cta-h2 em   { font-style: italic; color: var(--gold-light); }
.cta-sub     { font-size: 14px; color: rgba(245,240,232,.55); margin-bottom: 32px; line-height: 1.6; }
.btn-primary { background: var(--gold); color: var(--forest); font-family: var(--sans); font-size: 11px; font-weight: 500; letter-spacing: .1em; text-transform: uppercase; padding: 14px 32px; border-radius: 2px; text-decoration: none; display: inline-block; transition: background .2s; }
.btn-primary:hover { background: var(--gold-light); }
</style>
