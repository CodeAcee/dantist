# ─── Sanity (content: services, cases, team, reviews, media) ─
# Project ID and dataset live in studio/sanity.config.ts

PUBLIC_SANITY_PROJECT_ID=xxxxxxxx
PUBLIC_SANITY_DATASET=production

# ─── Contact form → Cloudflare Worker → Telegram ────────────
# Deploy the Worker in worker/ (wrangler deploy), then paste its
# *.workers.dev URL here. Bot token/chat ID are Worker secrets
# (wrangler secret put TELEGRAM_BOT_TOKEN / TELEGRAM_CHAT_ID),
# not needed in this file.

PUBLIC_CONTACT_WORKER_URL=https://chirkova-contact.<your-subdomain>.workers.dev
